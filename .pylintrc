[MASTER]
load-plugins=pylint_django
django-settings-module=config.settings

[MESSAGES CONTROL]
disable=
    missing-docstring,
    invalid-name,
    too-few-public-methods,
    no-member,
    too-many-ancestors

[TYPECHECK]
ignored-modules=django
ignored-classes=ForeignKey,OneToOneField,ManyToManyField

[FORMAT]
max-line-length=100